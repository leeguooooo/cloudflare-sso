{
  "name": "cloudflare-sso",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "wrangler:config:prod": "node scripts/use-wrangler-config.mjs prod",
    "deploy": "pnpm deploy:prod",
    "deploy:prod": "pnpm wrangler:config:prod && pnpm build && wrangler pages deploy dist --project-name cloudflare-sso",
    "logs:prod": "pnpm wrangler:config:prod && wrangler pages deployment tail --project-name cloudflare-sso --environment production --format pretty",
    "setup:pages": "node scripts/setup-pages-config.mjs",
    "setup:pages:sh": "./scripts/setup-pages.sh"
  },
  "dependencies": {
    "@leeguoo/design-tokens": "link:../cherry/packages/design-tokens",
    "@leeguoo/leeguoo-ui-vue": "link:../cherry/packages/ui-vue",
    "@nuxtjs/i18n": "^9.0.0",
    "@pinia/nuxt": "^0.11.2",
    "nuxt": "^4.2.0",
    "pinia": "^3.0.3"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.45.3"
  }
}
